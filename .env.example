# ============================================
# Agent Performance Monitor - Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=False

# ============================================
# Security & Secrets (USE STRONG VALUES)
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database Configuration
# ============================================
# Supported backends: sqlite, postgresql, mongodb
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///./apm.db

# PostgreSQL (if using postgresql)
# DATABASE_URL=postgresql://user:password@localhost:5432/apm_db

# MongoDB (if using mongodb)
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DATABASE=agent_performance_monitor

# ============================================
# API Keys & External Services
# ============================================
# GitHub Copilot Integration
GITHUB_TOKEN=
GITHUB_ORGANIZATION=

# OpenAI API (for token counting)
OPENAI_API_KEY=

# Anthropic API
ANTHROPIC_API_KEY=

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/apm.log
LOG_RETENTION_DAYS=30

# ============================================
# Monitoring & Metrics
# ============================================
ENABLE_PROMETHEUS=True
PROMETHEUS_PORT=9090
METRICS_RETENTION_HOURS=720

# ============================================
# Data Retention & Storage
# ============================================
MAX_EXECUTION_HISTORY_DAYS=90
ENABLE_DATA_COMPRESSION=True

# ============================================
# Alerting Configuration
# ============================================
ENABLE_ALERTS=True
ALERT_EMAIL_ENABLED=False
ALERT_EMAIL_FROM=alerts@apm.dev
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ============================================
# Feature Flags
# ============================================
FEATURE_COPILOT_INTEGRATION=True
FEATURE_LANGCHAIN_INTEGRATION=True
FEATURE_EXPORT_CSV=True
FEATURE_EXPORT_JSON=True
FEATURE_PROMETHEUS_EXPORT=True

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
