# ============================================
# Agent Performance Monitor - Production Configuration
# ============================================
# SECURITY: This is a template only. Never commit actual secrets.
# Use secure secret management (AWS Secrets Manager, HashiCorp Vault, etc.)

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=8
DEBUG=False

# ============================================
# Security & Secrets - MUST USE VAULT/SECRET MANAGER
# ============================================
# NEVER put actual secrets in .env files in production
# Use: AWS Secrets Manager, Azure Key Vault, HashiCorp Vault, or similar
SECRET_KEY=${VAULT_SECRET_KEY}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database Configuration - Production Grade
# ============================================
# Use managed databases (RDS, Cloud SQL, Atlas) in production
DATABASE_TYPE=postgresql
DATABASE_URL=${VAULT_DATABASE_URL}
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_RECYCLE=3600
DATABASE_SSL_MODE=require

# ============================================
# API Keys & External Services - VAULT ONLY
# ============================================
GITHUB_TOKEN=${VAULT_GITHUB_TOKEN}
GITHUB_ORGANIZATION=${VAULT_GITHUB_ORGANIZATION}
OPENAI_API_KEY=${VAULT_OPENAI_API_KEY}
ANTHROPIC_API_KEY=${VAULT_ANTHROPIC_API_KEY}

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=WARNING
LOG_FORMAT=json
LOG_FILE=/var/log/apm/apm.log
LOG_RETENTION_DAYS=90

# ============================================
# Monitoring & Metrics
# ============================================
ENABLE_PROMETHEUS=True
PROMETHEUS_PORT=9090
METRICS_RETENTION_HOURS=720

# ============================================
# Data Retention & Storage
# ============================================
MAX_EXECUTION_HISTORY_DAYS=365
ENABLE_DATA_COMPRESSION=True

# ============================================
# Alerting Configuration
# ============================================
ENABLE_ALERTS=True
ALERT_EMAIL_ENABLED=True
ALERT_EMAIL_FROM=${VAULT_ALERT_EMAIL}
SMTP_SERVER=${VAULT_SMTP_SERVER}
SMTP_PORT=${VAULT_SMTP_PORT}
SMTP_USERNAME=${VAULT_SMTP_USERNAME}
SMTP_PASSWORD=${VAULT_SMTP_PASSWORD}

# ============================================
# Feature Flags - Production
# ============================================
FEATURE_COPILOT_INTEGRATION=True
FEATURE_LANGCHAIN_INTEGRATION=True
FEATURE_EXPORT_CSV=True
FEATURE_EXPORT_JSON=True
FEATURE_PROMETHEUS_EXPORT=True

# ============================================
# CORS Configuration - Production
# ============================================
CORS_ALLOWED_ORIGINS=https://apm.yourdomain.com,https://dashboard.yourdomain.com
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*
