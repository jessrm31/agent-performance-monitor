# ============================================
# Agent Performance Monitor - Test Configuration
# ============================================
# Used ONLY for testing - contains dummy values

API_HOST=127.0.0.1
API_PORT=8001
API_WORKERS=1
DEBUG=True

# ============================================
# Security & Secrets - DUMMY VALUES FOR TESTING
# ============================================
SECRET_KEY=test-secret-key-only-for-testing-do-not-use
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database Configuration - SQLite for tests
# ============================================
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite:///:memory:

# ============================================
# API Keys & External Services - Dummy
# ============================================
GITHUB_TOKEN=test-token-only-for-testing
GITHUB_ORGANIZATION=test-org
OPENAI_API_KEY=test-api-key-only-for-testing
ANTHROPIC_API_KEY=test-api-key-only-for-testing

# ============================================
# Logging Configuration - Testing
# ============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_FILE=
LOG_RETENTION_DAYS=1

# ============================================
# Monitoring & Metrics
# ============================================
ENABLE_PROMETHEUS=False
PROMETHEUS_PORT=9090
METRICS_RETENTION_HOURS=24

# ============================================
# Feature Flags - Testing
# ============================================
FEATURE_COPILOT_INTEGRATION=True
FEATURE_LANGCHAIN_INTEGRATION=True
FEATURE_EXPORT_CSV=True
FEATURE_EXPORT_JSON=True
FEATURE_PROMETHEUS_EXPORT=False
